generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- MÓDULO DE DADOS MESTRES ---
model CategoryMaster {
  id               String       @id @default(uuid())
  name             String
  unitCost         Float
  taxRate          Float
  agingPenaltyRate Float
  marketStock      Int
  stockInputs      StockInput[]
}

model CapexMaster {
  id            String       @id @default(uuid())
  name          String
  description   String
  cost          Float
  baseLicense   Float
  upgradeImpact Float
  storeCapexs   StoreCapex[]
}

// --- MÓDULO DE SESSÃO E USUÁRIOS ---
model GameSession {
  id           String          @id @default(cuid())
  code         String          @unique 
  status       String          @default("LOBBY")
  currentRound Int             @default(1)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime?        @updatedAt // Adicionado para controle de tempo real

  players      Player[]
  configs      Configuration[]
  results      RoundResult[]
}

model Player {
  id        String       @id @default(cuid())
  name      String
  email     String       @unique
  storeName String
  role      String       @default("player")
  socketId  String?
  isActive  Boolean      @default(true)
  
  sessionId String?
  session   GameSession? @relation(fields: [sessionId], references: [id])
  
  store     Store?       // Relação 1:1 mantida
  
  scores    Score[]
  createdAt DateTime     @default(now())
  updatedAt DateTime?     @updatedAt
}

model Score {
  id        String   @id @default(cuid())
  round     Int
  value     Float    @default(0)
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([playerId, round])
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
}

// --- MÓDULO DA OPERAÇÃO ---
model Store {
  id             String          @id @default(uuid())
  name           String
  initialCash    Float           @default(700000.0)
  
  playerId       String?          @unique
  player         Player?          @relation(fields: [playerId], references: [id], onDelete: Cascade)

  configurations Configuration[]
  rounds         RoundResult[]
}

model Configuration {
  id                  String       @id @default(uuid())
  storeId             String
  sessionId           String?      // Tornamos opcional (?) para o db push não quebrar dados antigos
  roundNumber         Int
  
  operatorsQty        Int          @default(0)
  serviceOperatorsQty Int          @default(0)
  quizScore           Float        @default(0.0)
  totalSpent          Float        @default(0)
  interestPaid        Float        @default(0)
  
  finalCSAT           Float?
  finalSLA            Int?
  
  createdAt           DateTime     @default(now())
  
  store               Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  session             GameSession? @relation(fields: [sessionId], references: [id])
  stockInputs         StockInput[]
  capexSelections     StoreCapex[]

  @@unique([storeId, roundNumber])
}

model StockInput {
  id            String         @id @default(uuid())
  configId      String
  categoryId    String
  buyQty        Int
  appliedMargin Float 
  
  category      CategoryMaster @relation(fields: [categoryId], references: [id])
  config        Configuration  @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, categoryId])
}

model StoreCapex {
  id          String        @id @default(uuid())
  configId    String
  capexId     String
  isApproved  Boolean       @default(false)
  
  capexMaster CapexMaster   @relation(fields: [capexId], references: [id])
  config      Configuration @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, capexId])
}

model RoundResult {
  id             String      @id @default(uuid())
  storeId        String
  sessionId      String?     // Opcional para migração segura
  roundNumber    Int
  
  totalRevenue   Float
  totalCMV       Float
  operatingCosts Float
  agingCosts     Float
  ebitdaValue    Float
  ebitdaMargin   Float
  remainingStock Int
  marketShare    Float
  
  store          Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  session        GameSession? @relation(fields: [sessionId], references: [id])
}