generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model CategoryMaster {
  id               String       @id @default(uuid())
  name             String
  unitCost         Float
  taxRate          Float
  agingPenaltyRate Float
  marketStock      Int
  stockInputs      StockInput[]
}

model CapexMaster {
  id            String       @id @default(uuid())
  name          String
  description   String
  cost          Float
  baseLicense   Float
  upgradeImpact Float
  storeCapexs   StoreCapex[]
}

model Store {
  id             String          @id @default(uuid())
  name           String
  initialCash    Float           @default(700000.0)
  configurations Configuration[]
  rounds         RoundResult[]
}

model Configuration {
  id                  String       @id @default(uuid())
  storeId             String
  roundNumber         Int
  operatorsQty        Int          @default(0)
  serviceOperatorsQty Int          @default(0)
  quizScore           Float        @default(0.0)
  totalSpent          Float        @default(0)
  interestPaid        Float        @default(0)
  finalCSAT           Float?
  finalSLA            Int?
  createdAt           DateTime     @default(now())
  store               Store        @relation(fields: [storeId], references: [id])
  stockInputs         StockInput[]
  capexSelections     StoreCapex[]
}

model StockInput {
  id            String         @id @default(uuid())
  configId      String
  categoryId    String
  buyQty        Int
  appliedMargin Float
  category      CategoryMaster @relation(fields: [categoryId], references: [id])
  config        Configuration  @relation(fields: [configId], references: [id])
}

model StoreCapex {
  id          String        @id @default(uuid())
  configId    String
  capexId     String
  isApproved  Boolean       @default(false)
  capexMaster CapexMaster   @relation(fields: [capexId], references: [id])
  config      Configuration @relation(fields: [configId], references: [id])
}

model RoundResult {
  id             String @id @default(uuid())
  storeId        String
  roundNumber    Int
  totalRevenue   Float
  totalCMV       Float
  operatingCosts Float
  agingCosts     Float
  ebitdaValue    Float
  ebitdaMargin   Float
  remainingStock Int
  marketShare    Float
  store          Store  @relation(fields: [storeId], references: [id])
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
}



model GameSession {
  id           String   @id @default(cuid())
  // Garantimos que o código seja sempre salvo em maiúsculo no banco via Service
  code         String   @unique 
  status       String   @default("LOBBY") // LOBBY, START, FINISHED
  currentRound Int      @default(1)
  createdAt    DateTime @default(now())
  players      Player[]
}

model Player {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  storeName String
  role      String   @default("player")
  socketId  String?
  isActive  Boolean  @default(true)
  
  // O sessionId (UUID) é o que faz o relacionamento real no banco
  sessionId String?
  session   GameSession? @relation(fields: [sessionId], references: [id])
  
  createdAt DateTime @default(now())
  scores    Score[]
}

model Score {
  id        String   @id @default(cuid())
  round     Int
  value     Float    @default(0)
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id])
  createdAt DateTime @default(now())

  @@unique([playerId, round])
}