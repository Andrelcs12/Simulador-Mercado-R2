generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model GameSession {
  id             String            @id @default(cuid())
  code           String            @unique
  status         GameSessionStatus @default(LOBBY)
  totalRounds    Int               @default(3)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  currentRound   Int               @default(0)
  configurations Configuration[]
  rounds         GameRound[]
  players        Player[]
  roundRankings  RoundRanking[]
  roundResults   RoundResult[]
  sessionResults SessionResult[]
  stores         Store[]
}

model GameRound {
  id             String          @id @default(cuid())
  sessionId      String
  roundNumber    Int
  status         GameRoundStatus @default(CLOSED)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime        @default(now())
  configurations Configuration[]
  session        GameSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  rankings       RoundRanking[]
  results        RoundResult[]

  @@unique([sessionId, roundNumber])
}

model Player {
  id        String      @id @default(cuid())
  name      String
  socketId  String?
  sessionId String
  createdAt DateTime    @default(now())
  storeId   String?
  role      PlayerRole
  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  store     Store?      @relation(fields: [storeId], references: [id])
}

model Store {
  id                 String          @id @default(uuid())
  name               String
  cashBalance        Float           @default(700000)
  createdAt          DateTime        @default(now())
  accumulatedEbitda  Float           @default(0)
  accumulatedProfit  Float           @default(0)
  accumulatedRevenue Float           @default(0)
  currentCSAT        Float           @default(0)
  currentSLA         Float           @default(0)
  sessionId          String
  configurations     Configuration[]
  players            Player[]
  rankings           RoundRanking[]
  roundResults       RoundResult[]
  sessionResults     SessionResult[]
  session            GameSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model CategoryMaster {
  id               String       @id @default(uuid())
  name             String
  unitCost         Float
  taxRate          Float
  agingPenaltyRate Float
  totalMarketStock Int
  stockInputs      StockInput[]
}

model CapexMaster {
  id                   String       @id @default(uuid())
  name                 String
  description          String
  cost                 Float
  csatImpact           Float        @default(0)
  productivityImpact   Float        @default(0)
  recurringLicenseCost Float        @default(0)
  slaImpact            Float        @default(0)
  storeCapexes         StoreCapex[]
}

model Configuration {
  id                  String       @id @default(uuid())
  storeId             String
  operatorsQty        Int
  serviceOperatorsQty Int
  quizScore           Float
  createdAt           DateTime     @default(now())
  roundId             String
  sessionId           String
  submittedAt         DateTime     @default(now())
  calculatedCSAT      Float?
  calculatedSLA       Float?
  totalInvestment     Float        @default(0)
  round               GameRound    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  session             GameSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  store               Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  stockInputs         StockInput[]
  capexSelections     StoreCapex[]

  @@unique([storeId, roundId])
}

model StockInput {
  id                String         @id @default(uuid())
  categoryId        String
  buyQty            Int
  commercialMargin  Float
  configurationId   String
  createdAt         DateTime       @default(now())
  expectedSellPrice Float
  category          CategoryMaster @relation(fields: [categoryId], references: [id])
  configuration     Configuration  @relation(fields: [configurationId], references: [id], onDelete: Cascade)
}

model StoreCapex {
  id              String        @id @default(uuid())
  capexId         String
  approved        Boolean       @default(false)
  configurationId String
  createdAt       DateTime      @default(now())
  capex           CapexMaster   @relation(fields: [capexId], references: [id])
  configuration   Configuration @relation(fields: [configurationId], references: [id], onDelete: Cascade)
}

model RoundRanking {
  id                String      @id @default(uuid())
  sessionId         String
  roundId           String
  storeId           String
  priceScore        Float
  availabilityScore Float
  csatScore         Float
  finalScore        Float
  position          Int
  createdAt         DateTime    @default(now())
  marketShare       Float
  roundNumber       Int
  round             GameRound   @relation(fields: [roundId], references: [id], onDelete: Cascade)
  session           GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  store             Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([sessionId, roundId, storeId])
  @@index([sessionId, roundNumber])
  @@index([sessionId, roundId])
}

model RoundResult {
  id                  String      @id @default(uuid())
  storeId             String
  totalRevenue        Float
  totalCMV            Float
  operatingCosts      Float
  agingCosts          Float
  ebitdaValue         Float
  ebitdaMargin        Float
  createdAt           DateTime    @default(now())
  roundId             String
  sessionId           String
  finalCash           Float
  capexCosts          Float
  csat                Float
  customersReceived   Float
  interestCosts       Float
  licensingCosts      Float
  remainingStockValue Float
  sla                 Float
  stockBreakLoss      Float
  totalExpenses       Float
  totalTaxes          Float
  marketShare         Float       @default(0)
  availabilityRate    Float       @default(0)
  averagePrice        Float       @default(0)
  round               GameRound   @relation(fields: [roundId], references: [id], onDelete: Cascade)
  session             GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  store               Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, roundId])
  @@index([sessionId, roundId])
}

model SessionResult {
  id                String      @id @default(uuid())
  sessionId         String
  storeId           String
  totalRevenue      Float
  finalScore        Float
  position          Int
  createdAt         DateTime    @default(now())
  finalCash         Float
  finalEbitda       Float
  finalEbitdaMargin Float
  totalExpenses     Float
  finalMarketShare  Float
  session           GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  store             Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([sessionId, storeId])
  @@index([sessionId])
}

enum GameSessionStatus {
  LOBBY
  IN_PROGRESS
  FINISHED
}

enum GameRoundStatus {
  OPEN
  CLOSED
  PROCESSED
  PROCESSING
}

enum PlayerRole {
  STORE_MANAGER
  SERVICE_MANAGER
  SUPPLY_MANAGER
  COMMERCIAL_MANAGER
  OPERATION_MANAGER
}
