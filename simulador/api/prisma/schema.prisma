generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===============================
// ENUMS
// ===============================

enum GameSessionStatus {
  LOBBY
  IN_PROGRESS
  FINISHED
}

enum GameRoundStatus {
  CLOSED
  OPEN
  PROCESSING
  PROCESSED
}

enum PlayerRole {
  STORE_MANAGER
  SERVICE_MANAGER
  SUPPLY_MANAGER
  COMMERCIAL_MANAGER
  OPERATION_MANAGER
}

// ===============================
// SESSION
// ===============================

model GameSession {
  id String @id @default(cuid())

  code String @unique

  status GameSessionStatus @default(LOBBY)

  totalRounds  Int @default(3)
  currentRound Int @default(0)

  players Player[]
  stores  Store[]
  rounds  GameRound[]

  configurations Configuration[]

  roundResults RoundResult[]

  roundRankings RoundRanking[]

  sessionResults SessionResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===============================
// ROUND
// ===============================

model GameRound {
  id String @id @default(cuid())

  sessionId String
  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  roundNumber Int

  status GameRoundStatus @default(CLOSED)

  startsAt DateTime?
  endsAt   DateTime?

  configurations Configuration[]
  results        RoundResult[]
  rankings       RoundRanking[]

  createdAt DateTime @default(now())

  @@unique([sessionId, roundNumber])
}

// ===============================
// PLAYER
// ===============================

model Player {
  id String @id @default(cuid())

  name  String
  email String @unique

  role PlayerRole

  socketId String?

  sessionId String
  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

// ===============================
// STORE
// ===============================

model Store {
  id String @id @default(uuid())

  name String

  sessionId String
  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  cashBalance Float @default(700000)

  accumulatedRevenue Float @default(0)
  accumulatedProfit  Float @default(0)
  accumulatedEbitda  Float @default(0)

  currentCSAT Float @default(0)
  currentSLA  Float @default(0)

  players Player[]

  configurations Configuration[]

  roundResults RoundResult[]

  rankings RoundRanking[]

  sessionResults SessionResult[]

  createdAt DateTime @default(now())

  @@index([sessionId])
}

// ===============================
// CATEGORY
// ===============================

model CategoryMaster {
  id String @id @default(uuid())

  name String

  unitCost Float
  taxRate  Float

  agingPenaltyRate Float

  totalMarketStock Int

  stockInputs StockInput[]
}

// ===============================
// CAPEX
// ===============================

model CapexMaster {
  id String @id @default(uuid())

  name        String
  description String

  cost Float

  recurringLicenseCost Float @default(0)

  slaImpact  Float @default(0)
  csatImpact Float @default(0)

  productivityImpact Float @default(0)

  storeCapexes StoreCapex[]
}

// ===============================
// CONFIGURATION
// ===============================

model Configuration {
  id String @id @default(uuid())

  sessionId String
  roundId   String
  storeId   String

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  round GameRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  operatorsQty Int

  serviceOperatorsQty Int

  quizScore Float

  calculatedCSAT Float?
  calculatedSLA  Float?

  totalInvestment Float @default(0)

  submittedAt DateTime @default(now())

  stockInputs StockInput[]

  capexSelections StoreCapex[]

  createdAt DateTime @default(now())

  @@unique([storeId, roundId])
}

// ===============================
// STOCK INPUT
// ===============================

model StockInput {
  id String @id @default(uuid())

  configurationId String

  configuration Configuration @relation(fields: [configurationId], references: [id], onDelete: Cascade)

  categoryId String

  category CategoryMaster @relation(fields: [categoryId], references: [id])

  buyQty Int

  commercialMargin Float

  expectedSellPrice Float

  createdAt DateTime @default(now())
}

// ===============================
// STORE CAPEX
// ===============================

model StoreCapex {
  id String @id @default(uuid())

  configurationId String

  configuration Configuration @relation(fields: [configurationId], references: [id], onDelete: Cascade)

  capexId String

  capex CapexMaster @relation(fields: [capexId], references: [id])

  approved Boolean @default(false)

  createdAt DateTime @default(now())
}

// ===============================
// ROUND RANKING
// ===============================

model RoundRanking {
  id String @id @default(uuid())

  sessionId String
  roundId   String
  storeId   String

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  round GameRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  priceScore        Float
  availabilityScore Float
  csatScore         Float

  finalScore Float

  demandShare Float

  position Int

  createdAt DateTime @default(now())

  @@unique([roundId, storeId])
  @@index([sessionId, roundId])
}

// ===============================
// ROUND RESULT
// ===============================

model RoundResult {
  id String @id @default(uuid())

  sessionId String
  roundId   String
  storeId   String

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  round GameRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  customersReceived Float

  totalRevenue Float
  totalTaxes   Float
  totalCMV     Float

  operatingCosts Float
  capexCosts     Float
  licensingCosts Float
  agingCosts     Float
  interestCosts  Float

  totalExpenses Float

  ebitdaValue  Float
  ebitdaMargin Float

  finalCash Float

  remainingStockValue Float

  stockBreakLoss Float

  csat Float
  sla  Float

  createdAt DateTime @default(now())

  @@unique([storeId, roundId])
}

// ===============================
// SESSION RESULT
// ===============================

model SessionResult {
  id String @id @default(uuid())

  sessionId String
  storeId   String

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  totalRevenue Float

  totalExpenses Float

  finalEbitda Float

  finalEbitdaMargin Float

  finalCash Float

  finalScore Float

  position Int

  createdAt DateTime @default(now())

  @@unique([sessionId, storeId])
}
