// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 1. DADOS MESTRES (O que o Grupo D vai popular via Seed)
model CategoryMaster {
  id                String   @id @default(uuid())
  name              String   // Perecíveis, Mercearia, Eletro, Hipel
  unitCost          Float    // Ex: 20.00
  taxRate           Float    // Ex: 0.12 (12%)
  agingPenaltyRate  Float    // Ex: 0.20 (20%)
  marketStock       Int      // Qtd total disponível no mercado para todos
  stockInputs       StockInput[]
}

model CapexMaster {
  id            String   @id @default(uuid())
  name          String   // Segurança, Redes, Site, etc.
  description   String
  cost          Float    // Valor do investimento
  baseLicense   Float    // Valor da licença atual (R$ 500)
  upgradeImpact Float    // Multiplicador (Ex: 1.20 para 20%)
  storeCapexs   StoreCapex[]
}

// 2. ESTRUTURA DAS LOJAS (As competidoras)
model Store {
  id            String   @id @default(uuid())
  name          String   // GBarbosa, Bretas, Perini, Mercado Extra, etc.
  initialCash   Float    @default(700000.0)
  rounds        RoundResult[]
  configurations Configuration[]
}

// 3. CONFIGURAÇÃO DA RODADA (Inputs de cada grupo)
model Configuration {
  id                  String   @id @default(uuid())
  storeId             String
  store               Store    @relation(fields: [storeId], references: [id])
  roundNumber         Int      // 1, 2 ou 3

  // RH Inputs
  operatorsQty        Int      @default(0) // Quadro ideal: 10
  serviceOperatorsQty Int      @default(0) // Influencia SLA
  quizScore           Float    @default(0.0) // 0 a 1.0 (90% = 0.9)

  // Relacionamentos para inputs detalhados
  stockInputs         StockInput[]
  capexSelections     StoreCapex[]

  // Logs de cálculo (Para o Dev 2 e Grupo A salvarem o processamento)
  totalSpent          Float?   // Soma de tudo antes das vendas
  interestPaid        Float?   // Juros de 12% se estourar 700k
  finalCSAT           Float?
  finalSLA            Int?     // Dias de inatividade
  
  createdAt           DateTime @default(now())
}

// Detalhes da Compra de Estoque por Configuração
model StockInput {
  id              String         @id @default(uuid())
  configId        String
  config          Configuration  @relation(fields: [configId], references: [id])
  categoryId      String
  category        CategoryMaster @relation(fields: [categoryId], references: [id])
  buyQty          Int            // Qtd que a loja decidiu comprar
  appliedMargin   Float          // Margem decidida pelo Gerente Comercial
}

// Seleção de CAPEX por Loja
model StoreCapex {
  id          String        @id @default(uuid())
  configId    String
  config      Configuration @relation(fields: [configId], references: [id])
  capexId     String
  capexMaster CapexMaster   @relation(fields: [capexId], references: [id])
  isApproved  Boolean       @default(false)
}

// 4. RESULTADOS FINAIS (Output do Grupo A)
model RoundResult {
  id              String        @id @default(uuid())
  storeId         String
  store           Store         @relation(fields: [storeId], references: [id])
  roundNumber     Int
  
  totalRevenue    Float         // Faturamento Bruto
  totalCMV        Float         // Custo da mercadoria vendida
  operatingCosts  Float         // Folha + Licenças + Manutenção
  agingCosts      Float         // Penalidade por estoque parado
  ebitdaValue     Float
  ebitdaMargin    Float         // EBITDA %
  remainingStock  Int           // Qtd que sobrou para cálculo de Aging
  marketShare     Float         // % da demanda capturada
}


model User {
  id String @id @default(cuid())
  name String
  email String @unique
  password String
}
